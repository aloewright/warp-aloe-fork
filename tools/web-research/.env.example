# Required: Firecrawl API key for search/scrape/extract.
# Get one at https://firecrawl.dev
FIRECRAWL_API_KEY=

# One of the following LLM providers must be configured.
# The CLIs auto-detect based on which keys are present
# (priority: ANTHROPIC > OPENAI > OPENROUTER).

# Anthropic (Claude). Default model: claude-sonnet-4-6
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI. Default reasoning model: o4-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
REASONING_MODEL=o4-mini

# OpenRouter (routes to many providers).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# Optional knobs
# Soft wall-clock budget for deep-research, in seconds (default 270 = 4.5 min)
DEEP_RESEARCH_MAX_SECONDS=270
# Max iteration depth for deep-research (default 7)
DEEP_RESEARCH_MAX_DEPTH=7
# Max URLs to extract per iteration (default 3)
DEEP_RESEARCH_MAX_URLS=3
