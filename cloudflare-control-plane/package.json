{
  "name": "helm-cloudflare-control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "helm": "./dist/cli/helm.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "helm": "tsx src/cli/helm.ts",
    "deploy:control-plane": "wrangler deploy -c wrangler.control-plane.toml",
    "deploy:agent-runtime": "wrangler deploy -c wrangler.agent-runtime.toml",
    "build:container": "bash scripts/build-agent-runtime.sh"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.5.2",
    "vitest": "^3.1.2",
    "wrangler": "^3.114.7"
  }
}
